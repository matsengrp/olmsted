{
  "name": "olmsted",
  "description": "Web app for visualizing pathogen evolution (forked from auspice by James Hadfield, Trevor Bedford and Richard Neher)",
  "author": "Eli Harkins, Christopher Small, (forked from auspice by James Hadfield, Trevor Bedford and Richard Neher)",
  "license": "AGPL",
  "homepage": "./",
  "engines": {
    "node": "20.x",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "postinstall": "npm run create-data-dir && npm run setup-eslint-plugin",
    "setup-eslint-plugin": "node scripts/setup-eslint-plugin.js",
    "clean": "rimraf _deploy/dist",
    "server": "node server.dist.js",
    "build:client": "NODE_ENV=production BABEL_ENV=production webpack --config webpack.config.prod.js",
    "build:client:perf": "NODE_ENV=production BABEL_ENV=productiontiming webpack --config webpack.config.prod.js",
    "build:electron": "NODE_ENV=production BABEL_ENV=production webpack --config webpack.config.electron.js",
    "build:server": "NODE_ENV=production BABEL_ENV=production webpack --config webpack.config.server.js",
    "build": "npm run clean && npm run build:client && npm run build:server",
    "build:start": "npm run build && npm run server",
    "build:start:perf": "npm run clean && npm run build:client:perf && npm run build:server && npm run server",
    "start": "BABEL_ENV=dev ./node_modules/.bin/babel-node server.js dev",
    "start:local": "BABEL_ENV=dev ./node_modules/.bin/babel-node server.js dev localData",
    "start:local:perf": "BABEL_ENV=devtiming ./node_modules/.bin/babel-node server.js dev localData",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json,css,md}\"",
    "run:electron": "npm run clean && npm run build:electron && npm run create-data-dir && ./node_modules/.bin/electron . ",
    "dist:electron": "npm run clean && npm run build:electron && npm run create-data-dir && electron-builder",
    "heroku-postbuild": "npm run build",
    "create-data-dir": "./bin/create-data-dir.sh",
    "test": "BABEL_ENV=test jest",
    "test:watch": "BABEL_ENV=test jest --watch",
    "test:coverage": "BABEL_ENV=test jest --coverage"
  },
  "dependencies": {
    "awesomplete": "^1.1.4",
    "binomial": "^0.2.0",
    "d3-array": "^3.2.4",
    "d3-axis": "^3.0.0",
    "d3-brush": "^3.0.0",
    "d3-collection": "^1.0.7",
    "d3-color": "^3.1.0",
    "d3-ease": "^3.0.1",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-time-format": "^4.1.0",
    "d3-timer": "^3.0.1",
    "d3-zoom": "^3.0.0",
    "dexie": "^4.3.0",
    "express-naked-redirect": "^0.1.3",
    "express-static-gzip": "^3.0.0",
    "js-yaml": "^4.1.1",
    "leaflet": "^1.4.0",
    "linspace": "^1.0.0",
    "lodash": "^4.18.1",
    "lodash-es": "^4.17.23",
    "mousetrap": "^1.6.2",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "outer-product": "0.0.4",
    "papaparse": "^5.5.3",
    "prop-types": "^15.8.1",
    "query-string": "^6.14.1",
    "react": "^19.2.4",
    "react-collapsible": "^2.8.0",
    "react-copy-to-clipboard": "^5.1.1",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-icons": "^5.6.0",
    "react-redux": "^9.2.0",
    "react-tweet-embed": "^2.0.0",
    "react-vega": "^8.0.0",
    "redux": "^5.0.1",
    "redux-thunk": "^3.1.0",
    "reselect": "^5.1.1",
    "terser-webpack-plugin": "^5.4.0",
    "uuid": "^13.0.0",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-lite": "^6.4.2",
    "webpack": "^5.105.4",
    "webpack-dev-middleware": "^8.0.2"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/node": "^7.29.0",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.24.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "babel-jest": "^30.3.0",
    "babel-loader": "^10.1.1",
    "babel-plugin-strip-function-call": "^1.0.2",
    "chokidar": "^5.0.0",
    "compression-webpack-plugin": "^12.0.0",
    "css-loader": "^7.1.4",
    "diff": "^8.0.4",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "express": "^5.2.1",
    "fake-indexeddb": "^6.2.5",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "json-loader": "^0.5.7",
    "prettier": "^3.8.1",
    "prettyjson": "^1.2.5",
    "react-refresh": "^0.18.0",
    "rimraf": "^5.0.7",
    "style-loader": "^4.0.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3",
    "webpack-hot-middleware": "^2.26.1",
    "webpack-shell-plugin": "^0.5.0"
  },
  "overrides": {
    "canvas-prebuilt": "npm:@empty/module@1.0.0",
    "yargs-parser": "^20.2.9",
    "react-collapsible": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "eslint-config-airbnb": {
      "eslint": "$eslint"
    }
  },
  "build": {
    "appId": "olmsted",
    "directories": {
      "output": "releases"
    },
    "files": [
      "data/*",
      "dist/*",
      "index.html",
      "index.js",
      "package.json"
    ],
    "dmg": {
      "contents": [
        {
          "x": 110,
          "y": 150
        },
        {
          "x": 240,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
