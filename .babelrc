{
  "presets": [
    "@babel/preset-react",
    ["@babel/preset-env", {
      "targets": {
        "node": "20"
      }
    }]
  ],
  "plugins": [
    ["@babel/plugin-proposal-decorators", { "legacy": true }]
  ],
  "env": {
    "dev": {
      "plugins": [
        ["react-refresh/babel", { "skipEnvCheck": true }]
      ]
    },
    "test": {
      "plugins": []
    }
  }
}
